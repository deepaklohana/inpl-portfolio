generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("editor")
  isActive      Boolean   @default(true)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model SeoMetadata {
  id               Int      @id @default(autoincrement())
  meta_title       String?
  meta_description String?
  og_image         String?
  keywords         String?
  no_index         Boolean  @default(false)
  created_at       DateTime @default(now())

  blogs    Blog[]
  events   Event[]
  news     News[]
  projects Project[]
  services Service[]
  product  Product?

  @@map("seo_metadata")
}

model Blog {
  id           Int     @id @default(autoincrement())
  title        String
  slug         String  @unique
  excerpt      String?
  content      String?
  cover_image  String?
  author_name  String?
  author_image String?
  category     String?
  tags         String?
  status       String  @default("draft")
  featured     Boolean @default(false)

  seo_id       Int?
  seo_metadata SeoMetadata? @relation(fields: [seo_id], references: [id], onDelete: SetNull)

  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("blogs")
}

model Event {
  id               Int       @id @default(autoincrement())
  title            String
  slug             String    @unique
  excerpt          String?
  description      String?
  cover_image      String?
  event_date       DateTime?
  end_date         DateTime?
  location         String?
  location_url     String?
  is_online        Boolean   @default(false)
  event_url        String?
  registration_url String?
  gallery          String[]
  status           String    @default("draft")
  featured         Boolean   @default(false)

  seo_id       Int?
  seo_metadata SeoMetadata? @relation(fields: [seo_id], references: [id], onDelete: SetNull)

  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("events")
}

model News {
  id          Int     @id @default(autoincrement())
  title       String
  slug        String  @unique
  excerpt     String?
  content     String?
  cover_image String?
  source_url  String?
  category    String?
  tags        String?
  author_name String?
  status      String  @default("draft")
  featured    Boolean @default(false)

  seo_id       Int?
  seo_metadata SeoMetadata? @relation(fields: [seo_id], references: [id], onDelete: SetNull)

  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("news")
}

model Project {
  id            Int       @id @default(autoincrement())
  title         String
  slug          String    @unique
  excerpt       String?
  description   String?
  cover_image   String?
  client_name   String?
  industry      String?
  tech_stack    String[]
  gallery       String[]
  project_url   String?
  start_date    DateTime?
  end_date      DateTime?
  sort_order    Int       @default(0)
  services_used String[]
  status        String    @default("draft")
  featured      Boolean   @default(false)

  seo_id       Int?
  seo_metadata SeoMetadata?  @relation(fields: [seo_id], references: [id], onDelete: SetNull)
  testimonials Testimonial[]

  published_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("projects")
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String?
  
  // For individual service page header
  blackHeading String?  // Main heading in black color
  blueHeading  String?  // Subheading in blue color

  // Service header
  icon        String?  // icon name or URL for the service pill
  pillText    String?  // text shown in the pill badge on service page

  // Stats bar — max 4 items
  stats       Json?    // StatItem[]

  // Sub-services section
  subServicesHeading    String?  // Heading for sub-services section
  subServicesDescription String? // Description for sub-services section
  subServices Json?    // SubService[]

  // Development process — exactly 4 steps
  processStepsHeading     String?
  processStepsDescription String?
  processSteps Json?   // ProcessStep[]

  // Conditional section discriminator
  sectionType  String  @default("technologies") // "technologies" | "tools"

  // Section A: Technology We Master
  techSection  Json?   // TechSection

  // Section B: Tools We Use
  toolsSection Json?   // ToolsSection

  // CTA Section
  ctaSection   Json?   // CtaSection

  // Publishing
  sort_order   Int      @default(0)
  status       String   @default("draft")  // "draft" | "published" | "archived"
  featured     Boolean  @default(false)
  published_at DateTime?

  // SEO
  seo_id       Int?
  seo_metadata SeoMetadata? @relation(fields: [seo_id], references: [id], onDelete: SetNull)

  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("services")
}

model Testimonial {
  id             Int     @id @default(autoincrement())
  client_name    String
  client_title   String?
  client_company String?
  company_type   String?
  client_image   String?
  content        String
  rating         Float   @default(5)
  status         String  @default("draft")
  featured       Boolean @default(false)
  sort_order     Int     @default(0)

  // Which public pages this testimonial should appear on
  // e.g. ["services", "home", "products"]
  showOnPages    String[]    @default([])

  // Direct product relations (many-to-many)
  products       ProductTestimonial[]

  project_id Int?
  projects   Project? @relation(fields: [project_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("testimonials")
}

model ProductTestimonial {
  id            Int     @id @default(autoincrement())
  productId     Int
  testimonialId Int
  sortOrder     Int     @default(0)

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  testimonial Testimonial @relation(fields: [testimonialId], references: [id], onDelete: Cascade)

  @@unique([productId, testimonialId])

  @@map("product_testimonials")
}

model Media {
  id            Int      @id @default(autoincrement())
  filename      String   @unique
  original_name String
  url           String
  mime_type     String
  size_bytes    Int
  folder        String   @default("general")
  created_at    DateTime @default(now())

  @@map("media")
}

model Product {
  id              Int             @id @default(autoincrement())
  name            String
  slug            String          @unique
  icon            String?
  userCount       String?
  fullName        String?
  shortDescription String?
  tagline         String?
  description     String?
  stats           Json?
  testimonialStats Json?
  trustedLogos    Json?
  whyChooseTitle  String?
  whyChooseDesc   String?
  whyChoosePoints Json?
  ctaTitle        String?
  ctaSubtitle     String?
  ctaButtonText   String?
  ctaButtonUrl    String?
  status          String          @default("draft")
  featured        Boolean         @default(false)
  sortOrder       Int             @default(0)
  modules         ProductModule[]
  seoId           Int?            @unique
  seo             SeoMetadata?    @relation(fields: [seoId], references: [id])

  // Direct product relations (many-to-many) to testimonials
  testimonials    ProductTestimonial[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ProductModule {
  id          Int             @id @default(autoincrement())
  productId   Int
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  slug        String?
  shortCode   String?
  description String?
  sortOrder   Int             @default(0)
  status      String          @default("published")
  features    ModuleFeature[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ModuleFeature {
  id               Int           @id @default(autoincrement())
  moduleId         Int
  module           ProductModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  name             String
  icon             String?
  shortDescription String?
  sortOrder        Int           @default(0)
  status           String        @default("published")
  createdAt        DateTime      @default(now())
}

model FAQ {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  sortOrder Int      @default(0)
  status    String   @default("published")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}
